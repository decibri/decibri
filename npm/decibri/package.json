{
  "name": "decibri",
  "version": "3.3.0",
  "description": "Cross-platform audio capture, output, and processing for Node.js and browsers",
  "main": "src/decibri.js",
  "types": "src/decibri.d.ts",
  "browser": "./src/browser/index.js",
  "exports": {
    ".": {
      "node": {
        "types": "./src/decibri.d.ts",
        "require": "./src/decibri.js",
        "import": "./src/decibri.js"
      },
      "browser": {
        "types": "./src/browser/index.d.ts",
        "default": "./src/browser/index.js"
      },
      "default": "./src/decibri.js"
    }
  },
  "license": "Apache-2.0",
  "engines": {
    "node": ">=18.0.0"
  },
  "os": [
    "win32",
    "darwin",
    "linux"
  ],
  "cpu": [
    "x64",
    "arm64"
  ],
  "keywords": [
    "audio",
    "microphone",
    "capture",
    "sound",
    "voice",
    "speech",
    "recording",
    "pcm",
    "stream",
    "real-time"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/decibri/decibri.git"
  },
  "homepage": "https://decibri.com",
  "bugs": {
    "url": "https://github.com/decibri/decibri/issues"
  },
  "napi": {
    "binaryName": "decibri",
    "targets": [
      "x86_64-pc-windows-msvc",
      "aarch64-apple-darwin",
      "x86_64-unknown-linux-gnu",
      "aarch64-unknown-linux-gnu"
    ]
  },
  "files": [
    "src/",
    "models/",
    "index.js",
    "index.d.ts",
    "README.md"
  ],
  "optionalDependencies": {
    "@decibri/decibri-win32-x64-msvc": "3.3.0",
    "@decibri/decibri-darwin-arm64": "3.3.0",
    "@decibri/decibri-linux-x64-gnu": "3.3.0",
    "@decibri/decibri-linux-arm64-gnu": "3.3.0"
  },
  "devDependencies": {
    "@napi-rs/cli": "^3.0.0"
  },
  "scripts": {
    "build": "napi build --platform --release -p decibri-node --manifest-path ../../bindings/node/Cargo.toml --js-package-name @decibri/decibri -o .",
    "artifacts": "napi artifacts",
    "version": "napi version"
  }
}
