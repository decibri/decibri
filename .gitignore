# Rust
/target/
**/*.rs.bk
Cargo.lock

# Node.js
node_modules/
npm-debug.log*
*.node

# napi-rs build artifacts
npm/decibri/*.node
npm/decibri/index.js
npm/decibri/index.d.ts

# Platform binary packages
npm/platform-win32-x64-msvc/*.node
npm/platform-darwin-arm64/*.node
npm/platform-linux-x64-gnu/*.node
npm/platform-linux-arm64-gnu/*.node

# Claude Code local settings
.claude/

# IDE
.idea/
.vscode/
*.swp
*.swo

# OS
.DS_Store
Thumbs.db

# Python bytecode and caches
__pycache__/
*.pyc
*.pyo

# Python virtual environments (uv defaults to .venv/)
.venv/
venv/

# Python packaging metadata
*.egg-info/

# Windows Python compiled extensions and MSVC debug symbols. Always build
# artifacts, never source. Safe to ignore globally because no legitimate
# tracked files use these extensions anywhere in the workspace.
*.pyd
*.pdb

# Maturin-built Python extension module binaries on non-Windows platforms.
# Scoped (not global) because `.so` and `.dylib` could legitimately be
# tracked elsewhere in future phases (e.g. bundled ORT runtimes under
# npm/platform-*/). Restrict the ignore to the exact path where `maturin
# develop` drops the `_decibri` editable install.
bindings/python/python/decibri/_decibri.so
bindings/python/python/decibri/_decibri.dylib
